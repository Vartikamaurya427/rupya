{
  "info": {
    "_postman_id": "9c7dc4bc-7f1b-4b6d-8de4-0a6779a04a61",
    "name": "Rupya Render - Deposits History APIs",
    "description": "Postman collection for user deposit initiate flow and admin deposits history/summary/status APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "  pm.collectionVariables.set('admin_token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "login"
              ]
            }
          }
        },
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.token) {",
                  "  pm.collectionVariables.set('user_token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"pin\": \"{{user_pin}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "User Deposits",
      "item": [
        {
          "name": "Initiate Deposit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.transaction_id) {",
                  "  pm.collectionVariables.set('transaction_id', jsonData.data.transaction_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000,\n  \"gateway\": \"UPI\",\n  \"remark\": \"Test deposit from Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/wallet/deposit/initiate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wallet",
                "deposit",
                "initiate"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Deposit Dashboard",
      "item": [
        {
          "name": "Get Deposits (All Filters)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && Array.isArray(jsonData.deposits) && jsonData.deposits.length > 0) {",
                  "  pm.collectionVariables.set('deposit_id', jsonData.deposits[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/deposits?page=1&limit=10&search=&status=&start_date=&end_date=&gateway=",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "deposits"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "status",
                  "value": ""
                },
                {
                  "key": "start_date",
                  "value": ""
                },
                {
                  "key": "end_date",
                  "value": ""
                },
                {
                  "key": "gateway",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get Deposits Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/deposits/summary?search=&start_date=&end_date=&gateway=",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "deposits",
                "summary"
              ],
              "query": [
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "start_date",
                  "value": ""
                },
                {
                  "key": "end_date",
                  "value": ""
                },
                {
                  "key": "gateway",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get User Deposits By UserId",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/users/{{target_user_id}}/deposits?page=1&limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "users",
                "{{target_user_id}}",
                "deposits"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Update Deposit Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"successful\",\n  \"remark\": \"Approved by admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/deposits/{{deposit_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "deposits",
                "{{deposit_id}}",
                "status"
              ]
            }
          }
        }
      ]
    }
  ],
