{
  "info": {
    "_postman_id": "f2c0db44-e434-4c1e-9f7f-aeb8e5a45920",
    "name": "Rupya Render - Service CRUD (Admin Dashboard)",
    "description": "Postman collection for admin dashboard service management APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Service APIs",
      "item": [
        {
          "name": "Create Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data._id) {",
                  "  pm.collectionVariables.set('service_id', jsonData.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Recharge\",\n  \"serviceName\": \"Mobile Recharge\",\n  \"processingTime\": \"5-10 min\",\n  \"icon\": \"https://example.com/icon.png\",\n  \"fixedCharge\": 10,\n  \"percentCharge\": 2.5,\n  \"serviceInstruction\": \"<p>Valid number enter karein</p>\",\n  \"userData\": [\n    {\n      \"label\": \"Mobile Number\",\n      \"key\": \"mobile\",\n      \"type\": \"text\",\n      \"required\": true\n    }\n  ],\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/services",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "services"
              ]
            }
          }
        },
        {
          "name": "Get Services (List)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/services?page=1&limit=10&search=&category=&isActive=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "services"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "category",
                  "value": ""
                },
                {
                  "key": "isActive",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Get Service By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/services/{{service_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "services",
                "{{service_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceName\": \"Mobile Recharge Updated\",\n  \"fixedCharge\": 12,\n  \"percentCharge\": 3,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/services/{{service_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "services",
                "{{service_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/dashboard/services/{{service_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "services",
                "{{service_id}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "service_id",
      "value": ""
    }
  ]
}
